{
  "schema": "apa-benchmark-index-v1",
  "policy": {
    "allowed_source_classes": [
      "public_patent",
      "public_office_action",
      "synthetic_disclosure",
      "synthetic_software_patent",
      "synthetic_codebase"
    ],
    "offline_commit_gate": true,
    "live_llm_eval": "periodic-advisory-only"
  },
  "cases": [
    {
      "id": "public-utility-patent-compile",
      "kind": "compiled-public-patent",
      "source_class": "public_patent",
      "source": "benchmarks/fixtures/public-utility-patent-compile/source.md",
      "matter": "benchmarks/fixtures/public-utility-patent-compile/expected-matter",
      "expected": "benchmarks/fixtures/public-utility-patent-compile/expected.json",
      "targeted_skills": ["apa-compile", "apa-validate", "apa-viewer"],
      "metrics": { "claim_concept_coverage": "mechanical", "support_edge_coverage": "mechanical" }
    },
    {
      "id": "public-office-action",
      "kind": "public-office-action",
      "source_class": "public_office_action",
      "office_action": "benchmarks/fixtures/public-office-action/office-action.md",
      "expected": "benchmarks/fixtures/public-office-action/expected.json",
      "targeted_skills": ["apa-office-action"],
      "metrics": { "rejection_parse_coverage": "mechanical", "deadline_estimate_shape": "mechanical" }
    },
    {
      "id": "synthetic-disclosure-to-assembly",
      "kind": "synthetic-disclosure-to-assembly",
      "source_class": "synthetic_disclosure",
      "matter": "examples/minimal-patent-artifact",
      "expected": "benchmarks/fixtures/synthetic-disclosure-to-assembly/expected.json",
      "targeted_skills": ["apa-disclose", "apa-claims", "apa-spec", "apa-figures", "apa-assemble"],
      "metrics": { "lifecycle_composition": "mechanical", "mock_eval_snapshot": "semantic" }
    },
    {
      "id": "software-patent-skill-sim",
      "kind": "software-patent-skill-simulation",
      "source_class": "synthetic_software_patent",
      "scenarios": "benchmarks/fixtures/software-patent-skill-sim/scenarios.json",
      "targeted_skills": ["apa-software-patent"],
      "metrics": { "scenario_pass_rate": "semantic-contract", "domain_output_contract": "mechanical" }
    },
    {
      "id": "synthetic-codebase-domain",
      "kind": "synthetic-codebase-domain",
      "source_class": "synthetic_codebase",
      "source": "benchmarks/fixtures/synthetic-codebase-domain/source-repo",
      "matter_template": "examples/minimal-patent-artifact",
      "expected": "benchmarks/fixtures/synthetic-codebase-domain/expected.json",
      "targeted_skills": [
        "apa-codebase-to-patent",
        "apa-software-disclosure-extractor",
        "apa-software-claim-patterns",
        "apa-software-101-review",
        "apa-software-architecture-figures"
      ],
      "metrics": { "domain_outputs": "mechanical", "mechanism_signal_coverage": "synthetic" }
    }
  ]
}

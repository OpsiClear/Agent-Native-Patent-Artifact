{
  "name": "agent-native-patent-artifact",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-Native Patent Artifact (APA) - a full-stack, agent-native tool that automates the patent-prep lifecycle. Phase-1 MVP: capture/compile into a machine-executable patent artifact, mechanically validate it, view it, and guard confidentiality. Human-in-the-loop; not legal advice.",
  "type": "module",
  "license": "MIT",
  "engines": { "node": ">=21" },
  "bin": {
    "apa-validate": "packages/apa-validate/validate.mjs",
    "apa-redact": "packages/apa-redact/cli.mjs",
    "apa-manifest": "packages/apa-viewer/build_manifest.mjs",
    "apa-safe": "packages/apa-safe/cli.mjs",
    "apa-safe-send": "packages/apa-safe/cli.mjs",
    "apa-safe-fetch": "packages/apa-safe/cli.mjs",
    "apa-safe-npx": "packages/apa-safe/cli.mjs",
    "apa-reports": "packages/apa-reports/cli.mjs",
    "apa-skillgraph": "packages/apa-skillgraph/cli.mjs",
    "apa-run": "packages/apa-run/cli.mjs",
    "apa-bench": "packages/apa-bench/cli.mjs",
    "apa-domain-software": "packages/apa-domain-software/cli.mjs",
    "apa-domain-device": "packages/apa-domain-device/cli.mjs",
    "apa-domain-formulation": "packages/apa-domain-formulation/cli.mjs"
  },
  "scripts": {
    "gen:skill-docs": "node scripts/gen-skill-docs.mjs",
    "gen:skill-docs:check": "node scripts/gen-skill-docs.mjs --check",
    "skillgraph": "node packages/apa-skillgraph/cli.mjs",
    "skillgraph:docs": "node packages/apa-skillgraph/cli.mjs docs",
    "skillgraph:check": "node packages/apa-skillgraph/cli.mjs check && node packages/apa-skillgraph/cli.mjs docs --check",
    "validate": "node packages/apa-validate/validate.mjs",
    "viewer:build": "node packages/apa-viewer/build_manifest.mjs",
    "syntax": "node scripts/check-syntax.mjs",
    "skills:check": "node scripts/check-skills.mjs",
    "sources:check": "node scripts/check-source-registry.mjs",
    "smoke": "node scripts/smoke.mjs",
    "benchmark": "node packages/apa-bench/cli.mjs --mock",
    "score:prior-art-search": "node packages/apa-bench/cli.mjs --mock --prior-art-recall",
    "score:real-software-patents": "node packages/apa-bench/cli.mjs --mock --real-software-patents",
    "tune:software-patent": "node packages/apa-bench/cli.mjs --mock --real-software-patents --fresh",
    "simulate:software-patent": "node packages/apa-bench/cli.mjs --mock --case software-patent-skill-sim",
    "coverage": "node scripts/coverage-summary.mjs",
    "test": "node --test \"packages/**/*.test.mjs\" \"lib/**/*.test.mjs\" \"scripts/**/*.test.mjs\" \"hosts/**/*.test.mjs\" \"test/**/*.test.mjs\"",
    "build": "node scripts/gen-skill-docs.mjs && node scripts/gen-skill-docs.mjs --check && node packages/apa-skillgraph/cli.mjs check && node packages/apa-skillgraph/cli.mjs docs --check && node scripts/check-syntax.mjs && node scripts/check-skills.mjs && node scripts/check-source-registry.mjs && node --test \"packages/**/*.test.mjs\" \"lib/**/*.test.mjs\" \"scripts/**/*.test.mjs\" \"hosts/**/*.test.mjs\" \"test/**/*.test.mjs\" && node scripts/smoke.mjs",
    "setup": "node scripts/setup.mjs"
  }
}
